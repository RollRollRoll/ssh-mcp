{
  "name": "@rollrollroll/ssh-mcp",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "ssh-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs/configuration.md"
  ],
  "workspaces": [
    "./web"
  ],
  "engines": {
    "node": ">=24 <27"
  },
  "scripts": {
    "build": "npm run build --workspace=web && tsc -p tsconfig.json",
    "prepack": "npm run build",
    "pretest": "npm run build",
    "typecheck": "tsc --noEmit && npm run typecheck --workspace=web",
    "test": "vitest run",
    "check": "npm run build && npm run typecheck && vitest run tests/unit tests/contract tests/acceptance && npm run test --workspace=web",
    "test:contract": "vitest run tests/contract",
    "test:acceptance": "vitest run tests/acceptance",
    "test:integration:linux": "node scripts/run-integration.mjs linux",
    "test:integration:windows": "node scripts/run-integration.mjs windows"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ssh2": "^1.16.0",
    "yaml": "^2.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "0.22.0",
    "@types/node": "^24.0.0",
    "@types/ssh2": "^1.15.5",
    "typescript": "^5.8.0",
    "vitest": "^4.1.10"
  }
}
